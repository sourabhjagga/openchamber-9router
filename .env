# OpenChamber Environment Configuration

# Set a secure UI password for OpenChamber (required for 0.0.0.0 binding)
OPENCHAMBER_UI_PASSWORD=

# Keep the host binding
OPENCHAMBER_HOST=0.0.0.0

# 9Router configuration
N9ROUTER_URL=http://9router:20128

# Neo4j credentials for Headroom graph memory
# IMPORTANT: Change this to a strong password before deploying!
NEO4J_AUTH=neo4j/devpassword
