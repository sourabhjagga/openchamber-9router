# Copy this to .env and fill in real values before deploying.
# In Coolify, set these as Environment Variables in your project dashboard.

# ── OpenChamber ──────────────────────────────────────────────────────────────
# Set a secure UI password for OpenChamber (required for 0.0.0.0 binding)
OPENCHAMBER_UI_PASSWORD=changeme

# ── Headroom / Neo4j ─────────────────────────────────────────────────────────
# Neo4j credentials used by headroom-proxy for graph memory.
# Format: username/password — CHANGE before deploying to production!
NEO4J_AUTH=neo4j/CHANGEME

# Optional: override the upstream LLM API endpoint that headroom-proxy forwards to.
# Useful if you want headroom to route to a local Ollama or a custom OpenAI-compatible API.
# Default behaviour (unset): headroom forwards to api.openai.com
# OPENAI_TARGET_API_URL=http://host-gateway:11434
