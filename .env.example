# Copy this to .env and fill in real values before deploying.
# In Coolify, set these as Environment Variables in your project dashboard.

# ── Open WebUI ──────────────────────────────────────────────────────────────
# Secret key for session encryption. Change this to a random string!
WEBUI_SECRET_KEY=changeme

# ── DeerFlow ────────────────────────────────────────────────────────────────
# Required: random secret string for frontend auth/session security
BETTER_AUTH_SECRET=changeme-set-a-real-secret

# Required: internal auth token for DeerFlow multi-worker channels
DEER_FLOW_INTERNAL_AUTH_TOKEN=changeme

# Optional: LangSmith tracing (leave false unless you use LangSmith)
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=your-key-here
